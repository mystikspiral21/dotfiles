[Desktop Entry]
Name=Text Editor
Comment=Edit text files
Exec=xed %U
Terminal=false
Type=Application
StartupNotify=true
MimeType=text/plain;application/x-zerosize;
Icon=accessories-text-editor
Categories=GTK;Utility;TextEditor;
Keywords=xed;text;editor;tabs;highlighting;code;multiple;files;pluggable;notepad;
X-MATE-DocPath=xed/xed.xml
Actions=new-window;
X-XFCE-Source=file:///usr/share/applications/org.x.editor.desktop

[Desktop Action new-window]
Name=New Window
Exec=xed --new-window %U
