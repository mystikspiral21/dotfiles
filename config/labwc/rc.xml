<?xml version="1.0" encoding="UTF-8"?>
<labwc_config>

  <keyboard>
    <default />

    <keybind key="W-grave">
      <action name="Execute" command="xfce4-terminal --drop-down" />
    </keybind>
 
    <keybind key="F12">
      <action name="Execute" command="qterminal -d" />
    </keybind>

    <keybind key="Print">
      <action name="Execute" command="sh -c 'mkdir -p ~/Pictures/Screenshots &amp;&amp; FILE=&quot;~/Pictures/Screenshots/$(date +%Y-%m-%d_%H-%M-%S).png&quot; &amp;&amp; grim -g &quot;$(slurp)&quot; &quot;$FILE&quot; &amp;&amp; wl-copy &lt; &quot;$FILE&quot;'" />
    </keybind> 

  </keyboard>

    <desktops>
  <number>2</number>
  <names>
    <name>1</name>
    <name>2</name>
  </names>
    </desktops>

</labwc_config>
